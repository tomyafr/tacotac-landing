# ══════════════════════════════════════════════════════════════
#  TACOTAC — variables d'environnement
#  Copie ce fichier en ".env" (sans .example) et remplis les vraies valeurs.
#  Le .env n'est JAMAIS commité (voir .gitignore). N'y mets que des vraies clés.
# ══════════════════════════════════════════════════════════════

# ── OpenAI (génération des répliques) ───────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Secret pour signer le cookie device_id (anti-forge) ─────────
# Mets une longue chaîne aléatoire (ex: sortie de `openssl rand -hex 32`).
COOKIE_SECRET=change-moi-par-une-longue-chaine-aleatoire

# ── Port du serveur (par défaut 3000) ───────────────────────────
PORT=3000

# ── Stripe (Phase 2 — paiement) ─────────────────────────────────
# En DEV utilise les clés "test" (sk_test_… / pk_test_…), en PROD les "live".
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_WEEKLY=price_1TpFs7HNrMOsyZiCQXBWQLhI
STRIPE_PRICE_MONTHLY=price_1TpFtNHNrMOsyZiCWjyVp58q

# ── Resend (emails transactionnels : cadeau -10%, liens magiques) ───────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
GIFT_FROM_EMAIL=Tacotac <hello@taco-tac.app>

# ── Cadeau email -10% : coupon Stripe appliqué au mensuel ──
STRIPE_WELCOME_COUPON=xxxxxxxx

# ── URL publique de l'app (pour les redirections Stripe) ────────
PUBLIC_URL=http://localhost:3000

# ── Codes founders (séparés par des virgules) : lien à envoyer = PUBLIC_URL/app?founder=CODE ──
FOUNDER_CODES=TACO-F1-XXXXX,TACO-F2-XXXXX
